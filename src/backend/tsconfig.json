{
  "compilerOptions": {
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES6",
    "module": "ESNext",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0", // TODO: Fjernes når moduleResolution er oppdatert til NodeNext
    "skipLibCheck": true,
    "types": [
      "vitest/globals",
      "node",
      "@testing-library/jest-dom"
    ],
  },
}